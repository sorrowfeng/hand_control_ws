  <!-- ==================== 主从关节联动约束 ====================
    MuJoCo polycoef 语法:
      joint1(从动) = c[0] + c[1]*joint2(主动) + c[2]*joint2² + c[3]*joint2³ + c[4]*joint2⁴

    单位换算 (原始公式为角度°，MuJoCo 内部用弧度 rad):
      y_deg = C0 + C1*x_deg + C2*x_deg²
      c[0] = C0 × (π/180)
      c[1] = C1
      c[2] = C2 × (180/π)

    ┌──────────┬──────────────────────────────────────────────────────────┐
    │ 手指     │ 原始公式 (°)                  → polycoef (rad)          │
    ├──────────┼──────────────────────────────────────────────────────────┤
    │ 大拇指   │ -0.0008x²+0.929x-0.8639  → -0.015082 0.929 -0.045837   │
    │ 食指     │  0.0067x²+0.8847x+2.1926 →  0.038265 0.8847  0.383882  │
    │ 中指     │  0.0076x²+0.8485x+2.0597 →  0.035946 0.8485  0.435448  │
    │ 无名指   │  0.0079x²+0.8321x+2.4732 →  0.043170 0.8321  0.452637  │
    │ 小拇指   │  0.0075x²+0.7349x+2.0181 →  0.035218 0.7349  0.429718  │
    └──────────┴──────────────────────────────────────────────────────────┘
  ======================================================== -->
  <equality>
    <!-- 大拇指 IP (finger13, 从动) 跟随 MCP flexion (finger12, 主动) -->
    <joint name="eq_thumb"  joint1="finger13" joint2="finger12"
           polycoef="-0.015082 0.929 -0.045837 0 0"/>

    <!-- 食指 PIP (finger22, 从动) 跟随 MCP (finger21, 主动) -->
    <joint name="eq_index"  joint1="finger22" joint2="finger21"
           polycoef="0.038265 0.8847 0.383882 0 0"/>

    <!-- 中指 PIP (finger32, 从动) 跟随 MCP (finger31, 主动) -->
    <joint name="eq_middle" joint1="finger32" joint2="finger31"
           polycoef="0.035946 0.8485 0.435448 0 0"/>

    <!-- 无名指 PIP (finger42, 从动) 跟随 MCP (finger41, 主动) -->
    <joint name="eq_ring"   joint1="finger42" joint2="finger41"
           polycoef="0.043170 0.8321 0.452637 0 0"/>

    <!-- 小拇指 PIP (finger52, 从动) 跟随 MCP (finger51, 主动) -->
    <joint name="eq_pinky"  joint1="finger52" joint2="finger51"
           polycoef="0.035218 0.7349 0.429718 0 0"/>
  </equality>

  <!-- ==================== 执行器（6 个主动自由度）====================
    仅对主动关节添加执行器，从动关节 (finger13/22/32/42/52) 由 equality
    自动驱动，橡胶垫固连体无需执行器。
    kp=50  : 位置刚度（弹簧）
    kv=2.0 : 速度阻尼（速度反馈，与 joint damping 共同决定阻尼比）
    阻尼比 ζ = (kv + damping) / (2√(kp × armature))
             = (2.0 + 2.0) / (2√(50 × 0.01)) ≈ 2.83  → 过阻尼，无摇晃
  ======================================================== -->
  <actuator>
    <!-- 大拇指: 2 个主动 DOF -->
    <position name="act_finger11" joint="finger11" kp="50" kv="2.0" ctrlrange="0 1.75"/>
    <position name="act_finger12" joint="finger12" kp="50" kv="2.0" ctrlrange="0 1.40"/>

    <!-- 食指: 1 个主动 DOF (PIP 由 equality 驱动) -->
    <position name="act_finger21" joint="finger21" kp="50" kv="2.0" ctrlrange="0 1.40"/>

    <!-- 中指: 1 个主动 DOF -->
    <position name="act_finger31" joint="finger31" kp="50" kv="2.0" ctrlrange="0 1.40"/>

    <!-- 无名指: 1 个主动 DOF -->
    <position name="act_finger41" joint="finger41" kp="50" kv="2.0" ctrlrange="0 1.40"/>

    <!-- 小拇指: 1 个主动 DOF -->
    <position name="act_finger51" joint="finger51" kp="50" kv="2.0" ctrlrange="0 1.40"/>
  </actuator>

</mujoco>
